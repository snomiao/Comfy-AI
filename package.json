{
  "name": "comfy-ai",
  "version": "1.0.0",
  "description": "Comfy AI terminal — floating xterm.js panel (Chrome extension, userscript) + WebSocket PTY server CLI",
  "type": "module",
  "bin": {
    "comfy-ai": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snomiao/Comfy-AI.git"
  },
  "homepage": "https://github.com/snomiao/Comfy-AI#readme",
  "author": "snomiao <sno@comfy.org>",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev:extension": "vite --config vite.extension.config.ts",
    "dev:userscript": "vite --config vite.userscript.config.ts",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:userscript": "vite build --config vite.userscript.config.ts",
    "build:cli": "bun build ts/cli.ts --outfile dist/cli.js --target bun --sourcemap=none",
    "build": "bun run build:cli && bun run build:extension && bun run build:userscript"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "latest",
    "@types/chrome": "^0.1.40",
    "@types/yargs": "^17.0.35",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "esbuild": "^0.28.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-monkey": "^7.1.9"
  },
  "dependencies": {
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "yargs": "^18.0.0"
  }
}
